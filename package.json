{
 "name": "playwright_template",
 "version": "1.0.0",
 "description": "> Um guia **didático, prático e direto ao ponto** para você dominar os comandos básicos do Playwright começando pela instalação.",
 "main": "index.js",
 "scripts": {
  "lint": "eslint . --ext .js,.mjs,.cjs,.ts",
  "test:e2e": "npx playwright test --config playwright.config.js",
  "test:e2e:ui": "npx playwright test --config playwright.config.js --ui",
  "test:e2e:ci": "xvfb-run --auto-servernum npx playwright test --config playwright.config.js",
  "test:e2e:debug": "npx playwright test --config playwright.config.js  --project=chromium --debug",
  "test:e2e:report": "npx playwright show-report"
 },
 "repository": {
  "type": "git",
  "url": "git+https://github.com/reinaldorossetti/playwright_template.git"
 },
 "keywords": [],
 "author": "",
 "license": "ISC",
 "type": "module",
 "bugs": {
  "url": "https://github.com/reinaldorossetti/playwright_template/issues"
 },
 "homepage": "https://github.com/reinaldorossetti/playwright_template#readme",
 "devDependencies": {
  "@faker-js/faker": "^10.4.0",
  "@playwright/test": "1.59.1",
  "@types/node": "^25.6.0",
  "@typescript-eslint/eslint-plugin": "^8.58.2",
  "@typescript-eslint/parser": "^8.58.2",
  "dotenv": "^17.4.2",
  "eslint": "^8.57.1",
  "eslint-config-airbnb-base": "^15.0.0",
  "eslint-plugin-import": "^2.32.0"
 }
}
